jQuery(document).ready(function($) {
    // scroll current post in category into view
    /*
    $(window).on('load', function() {
      var $currentPost = $('#categories-list .list-sub-item.current-post');
      if ($currentPost.length) {
        $currentPost[0].scrollIntoView({
          behavior: 'smooth',
          block: 'center' // Optional: Align the element in the center of the container
        });
      }
    });*/
    
    // URL PARAMETERS
    const $categoriesPanel = $("#categories-panel");
    const $categoriesToggle = $("#categories-toggle"); // Select the toggle button
    const $categoriesTitle = $("#categories-title"); // Select the categories title
    const $isoOverlay = $("#iso-overlay"); // Select the overlay
    const urlParams = new URLSearchParams(window.location.search);

    // On page load, check if "categoriesPanel" is in the URL and toggle the class
    if ($categoriesPanel.length) {
        if (urlParams.get("categoriesPanel") === "show") {
            $('#categories-panel').addClass("show");
            $('#iso-overlay').addClass("show");
        }

        // Toggle the "show" class when the categories toggle is clicked
        $categoriesToggle.on("click", function() {
            $('#categories-panel').toggleClass("show");
            $('#iso-overlay').toggleClass("show");

            // Get the current URL and search params
            const url = new URL(window.location);
            const urlParams = url.searchParams;

            if ($categoriesPanel.hasClass("show")) {
                // Set the URL parameter to "show"
                urlParams.set("categoriesPanel", "show");
            } else {
                // Remove the parameter if not shown
                urlParams.delete("categoriesPanel");
            }

            // Update the URL without reloading the page, keeping other params intact
            window.history.replaceState({}, "", `${url.pathname}?${urlParams.toString()}`);
        });
    }

    // Check for "gameMode" parameter and apply the "game-mode" class
    if (urlParams.get("gameMode") === "on") {
        const $body = $("body");
        const $gameModeToggle = $("#game-mode-toggle");

        // Add classes only if "game-mode" is not already present
        if (!$body.hasClass("game-mode")) {
            $body.addClass("game-mode");
        }

        if ($gameModeToggle.length && !$gameModeToggle.hasClass("active")) {
            $gameModeToggle.addClass("active");
        }
    } 

    // Remove "show" class and URL parameter if #categories-title is clicked
    $categoriesTitle.on("click", function() {
        $categoriesPanel.removeClass("show");
        $isoOverlay.removeClass("show");

        // Get the current URL and search params
        const url = new URL(window.location);
        const urlParams = url.searchParams;

        // Remove the "categoriesPanel" parameter from the URL
        urlParams.delete("categoriesPanel");

        // Update the URL without reloading the page
        window.history.replaceState({}, "", `${url.pathname}?${urlParams.toString()}`);
    });
    
    // Remove "show" class and URL parameter if #iso-overlay is clicked
    $isoOverlay.on("click", function() {
        $categoriesPanel.removeClass("show");
        $isoOverlay.removeClass("show");

        // Get the current URL and search params
        const url = new URL(window.location);
        const urlParams = url.searchParams;

        // Remove the "categoriesPanel" parameter from the URL
        urlParams.delete("categoriesPanel");

        // Update the URL without reloading the page
        window.history.replaceState({}, "", `${url.pathname}?${urlParams.toString()}`);
    });


    /* INFO CONTENT */
    $('#info-content-toggle').on('click', function(e) {
        $('#info-content-toggle').toggleClass("show");
        $('#info-content-description').toggleClass("show");
    });

    /* INFO PANEL */
    $('#child-posts').on('click', '.child-post-item', function() {
        $('.child-post-item').removeClass("active");

        $(this).addClass("active");

        var newDescription = $(this).data('description');
        var newSVG = $(this).data('svg');

        $('#info-content-description').html(newDescription);
        $('#child-post-svg').html(newSVG);

        var postId = $(this).attr('class').match(/id-(\d+)/);
        if (postId) {
            postId = postId[1]; // Extract the number from the match

            // Find the corresponding .child-post-game element with the matching id
            var matchingGame = $('.child-post-game.id-' + postId);

           // Remove "active" class from all other .child-post-game elements
            $('.child-post-game').not(matchingGame).removeClass('active');

            // Add the "active" class to the matched element if it doesn't already have it
            if (!matchingGame.hasClass('active')) {
                matchingGame.addClass('active');
            }
        }
    });

    /* CLICK FIRST CHILD POST */
    window.onload = function() {
        var firstChildPostItem = document.querySelector('.child-post-item');

        if (firstChildPostItem) {
            firstChildPostItem.click();
        }

        $('#info-content-toggle').click();
    };

    /* GAME MODE TOGGLE */
    // Function to get URL parameters
    function getUrlParameter(name) {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get(name);
    }

    // Check if gameMode=on is in the URL
    if (getUrlParameter('gameMode') === 'on') {
        $('body').addClass("game-mode");
        $('#game-mode-toggle').addClass("active").attr('data-game-mode', 'true');
		
		// Run this after 1 second (1000 milliseconds)
		setTimeout(function () {
			$('#info-content-toggle').removeClass("show");
			$('#info-content-description').removeClass("show");
		}, 1000);
    }

    $('#game-mode-toggle').on('click', function(e) {
        e.preventDefault();
        
        const urlParams = new URLSearchParams(window.location.search);
        const isGameModeOn = urlParams.get('gameMode') === 'on';

        // Toggle classes
        $('body').toggleClass("game-mode");
        $(this).toggleClass("active");
		$('#info-content-toggle').removeClass("show");
        $('#info-content-description').removeClass("show");

        if (isGameModeOn) {
            urlParams.delete('gameMode'); // Remove parameter to turn off game mode
            this.setAttribute('data-game-mode', 'false');
        } else {
            urlParams.set('gameMode', 'on'); // Add parameter to turn on game mode
            this.setAttribute('data-game-mode', 'true');
        }

        // Construct new URL
        const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
        window.history.replaceState(null, '', newUrl);
    });
	
    // Up and Down Arrows
	const listItems = document.querySelectorAll('.child-post-item');
	const container = document.querySelector('#child-posts');

	document.addEventListener('keydown', (event) => {
		if (!listItems.length) return;

		// Find the currently active item
		let currentIndex = Array.from(listItems).findIndex(item => item.classList.contains('active'));

		// If no item is active, start from -1 (so first down arrow sets it to 0)
		if (currentIndex === -1) {
			currentIndex = -1;
		} else {
			listItems[currentIndex].classList.remove('active');
		}

		if (event.key === 'ArrowDown') {
			currentIndex = (currentIndex + 1) % listItems.length;
		} else if (event.key === 'ArrowUp') {
			currentIndex = (currentIndex - 1 + listItems.length) % listItems.length;
		} else {
			return; // Only act on arrow keys
		}

		// Add "active" class to the new item
		listItems[currentIndex].classList.add('active');

		// Trigger a click event on the current item
		listItems[currentIndex].click();

		// Ensure the active item is in view
		listItems[currentIndex].scrollIntoView({
			behavior: 'smooth',
			block: 'center' // You can use 'start', 'center', 'end', or 'nearest'
		});

		// Prevent default scrolling
		event.preventDefault();
	});

    
    // Remember URL parameters when an <a> tag inside #categories-panel is clicked
    $("#categories-panel a").on("click", function(e) {
        const urlParams = new URLSearchParams(window.location.search);
        const gameMode = urlParams.has('gameMode') ? '&gameMode=' + urlParams.get('gameMode') : '';
        const isoMode = urlParams.has('isoMode') ? '&isoMode=' + urlParams.get('isoMode') : '';
        const categoriesPanel = urlParams.has('categoriesPanel') ? '&categoriesPanel=' + urlParams.get('categoriesPanel') : '';

        let queryString = gameMode + isoMode + categoriesPanel;
        if (queryString) {
            queryString = queryString.replace('&', '?'); // Ensure first param starts with '?'
            // Modify the <a> tag's href to include the current URL parameters
            const currentHref = $(this).attr('href');
            const newHref = currentHref + queryString;
            $(this).attr('href', newHref);
        }
    });
	
	
	// Horizontal Scroll Drag
	const slider = document.querySelector('.other-topics-list');
	let isDown = false;
	let startX;
	let scrollLeft;

	slider.addEventListener('mousedown', (e) => {
	  isDown = true;
	  slider.classList.add('active');
	  slider.classList.add('noselect'); // <- prevent highlight
	  startX = e.pageX - slider.offsetLeft;
	  scrollLeft = slider.scrollLeft;
	});

	slider.addEventListener('mouseup', () => {
	  isDown = false;
	  slider.classList.remove('active');
	  slider.classList.remove('noselect'); // <- re-enable highlight
	});

	slider.addEventListener('mouseleave', () => {
	  isDown = false;
	  slider.classList.remove('active');
	  slider.classList.remove('noselect');
	});


	slider.addEventListener('mousemove', (e) => {
		if (!isDown) return;
		e.preventDefault();
		const x = e.pageX - slider.offsetLeft;
		const walk = (x - startX) * 2; // scroll speed multiplier
		slider.scrollLeft = scrollLeft - walk;
	});
	
	
	// SVG PAN ZOOM
	function initZoomableSVGs() {
		$(".zoomable > svg").each(function(index, svgElement) {
		  // console.log("Initializing pan/zoom for SVG #" + index);

		  // Initialize svg-pan-zoom for this SVG
		  svgPanZoom(svgElement, {
			zoomEnabled: true,
			controlIconsEnabled: true,
			fit: true,
			center: true,
			panEnabled: true,
			  
			// 🔧 Performance / responsiveness tweaks
		  	minZoom: 0.5,           // prevent zooming out too far
		  	maxZoom: 10,            // prevent zooming in too far
		  	zoomScaleSensitivity: 0.5, // higher = faster zoom speed
		  	panSpeed: 1.5,          // higher = faster drag/pan speed
		  	dblClickZoomEnabled: false, // disable double-click if it feels laggy

		  	// Animation settings
		  	refreshRate: 'auto'     // can also try 16 for ~60fps, 10 for faster redraws
		  });
		});
		
		$(svgElement).data("panzoom-initialized", true);
	  }

	  // Run once initially
	  $(window).on("load", initZoomableSVGs);

	  // Watch for SVG changes dynamically
	  const observer = new MutationObserver(function() {
		initZoomableSVGs();
	  });

	  $(".zoomable").each(function(_, el) {
		observer.observe(el, { childList: true, subtree: true });
	  });

});
